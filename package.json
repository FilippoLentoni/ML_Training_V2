{
  "name": "ml-training",
  "version": "1.0.0",
  "private": true,
  "bin": {
    "ml-training": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "npm run build && node -e \"require('./lib/ml-pipeline-stack.js'); require('./lib/application-stage.js'); require('./lib/deployment-pipeline-stack.js'); console.log('OK')\"",
    "synth": "cdk synth",
    "deploy:pipeline": "cdk deploy MlTrainingPipelineStack",
    "deploy:personal": "cdk deploy BurnerModelTraining-PersonalStack",
    "deploy:alpha": "cdk deploy BurnerModelTraining-AlphaStack",
    "deploy:gamma": "cdk deploy BurnerModelTraining-GammaStack",
    "deploy:prod": "cdk deploy BurnerModelTraining-ProdStack"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "aws-cdk": "^2.180.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
